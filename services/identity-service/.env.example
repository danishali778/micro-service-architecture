ENVIRONMENT=local
SERVICE_NAME=identity-service
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://identity_service:identity_service@127.0.0.1:5432/identity_service
SUPABASE_AUTH_URL=http://127.0.0.1:9999/auth/v1
SUPABASE_ANON_KEY=local-anon-key
SUPABASE_SERVICE_ROLE_KEY=local-service-role-key
SUPABASE_JWT_ISSUER=http://127.0.0.1:9999/auth/v1
SUPABASE_JWKS_URL=http://127.0.0.1:9999/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
INTERNAL_AUTH_MODE=local_header
