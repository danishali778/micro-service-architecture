SERVICE_NAME=api-gateway
ENVIRONMENT=local
LOG_LEVEL=INFO
PUBLIC_API_PREFIX=/api/v1

OIDC_ISSUER=http://127.0.0.1:9000
OIDC_AUDIENCE=api-gateway
OIDC_DISCOVERY_URL=http://127.0.0.1:9000/.well-known/openid-configuration
OIDC_JWKS_CACHE_TTL_SECONDS=300
OIDC_REFRESH_COOLDOWN_SECONDS=30

SCENARIO_SERVICE_URL=http://127.0.0.1:9100
DOWNSTREAM_CONNECT_TIMEOUT_MS=500
DOWNSTREAM_REQUEST_TIMEOUT_MS=3000
INTERNAL_AUTH_MODE=local_header

CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
