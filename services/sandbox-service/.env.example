ENVIRONMENT=local
SERVICE_NAME=sandbox-service
DATABASE_URL=postgresql+psycopg://sandbox:sandbox@127.0.0.1:5432/sandbox
INTERNAL_AUTH_MODE=local_header
SANDBOX_PROVIDER=local_fake
DEFAULT_LEASE_SECONDS=2700
MAX_LEASE_SECONDS=7200
IDEMPOTENCY_RETENTION_HOURS=24
PROVIDER_TIMEOUT_MS=3000
REQUIRE_CURRENT_MIGRATION=true
LOG_LEVEL=INFO

